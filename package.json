{
  "name": "actioncap",
  "version": "0.2.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "type": "module",
  "scripts": {
    "preinstall": "case \"$npm_execpath\" in *bun*) exit 0 ;; *) bunx only-allow bun ;; esac",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:firefox": "ACTIONCAP_BROWSER=firefox tsc --noEmit && ACTIONCAP_BROWSER=firefox vite build",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/results/payload-format.test.ts",
    "edge:package": "bun run build && node scripts/package-edge.mjs",
    "firefox:package": "bun run build:firefox && node scripts/package-firefox.mjs"
  },
  "dependencies": {
    "dexie": "^4.4.4",
    "highlight.js": "^11.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rrweb": "^2.1.0",
    "rrweb-player": "^2.1.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@types/chrome": "^0.2.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.3"
  }
}
