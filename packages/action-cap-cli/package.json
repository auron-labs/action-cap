{
  "name": "@auron-labs/action-cap-cli",
  "version": "0.2.0",
  "description": "CLI for analyzing ActionCap .bxdac session archives.",
  "license": "MIT",
  "homepage": "https://github.com/skye-z/ActionCap/tree/main/packages/action-cap-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skye-z/ActionCap.git",
    "directory": "packages/action-cap-cli"
  },
  "bugs": {
    "url": "https://github.com/skye-z/ActionCap/issues"
  },
  "packageManager": "bun@1.3.14",
  "type": "module",
  "bin": {
    "actioncap": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/cli.js"
    }
  },
  "scripts": {
    "preinstall": "case \"$npm_execpath\" in *bun*) exit 0 ;; *) bunx only-allow bun ;; esac",
    "dev": "bun run src/cli.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepack": "bun run build",
    "automd": "automd"
  },
  "dependencies": {
    "@toon-format/toon": "^4.0.0",
    "citty": "^0.2.2",
    "cli-table3": "^0.6.5",
    "consola": "^3.4.2",
    "pathe": "^2.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "automd": "^0.4.3",
    "typescript": "^7.0.2"
  }
}
